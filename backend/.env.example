NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/devportfolio
# Optional alias if your platform provides this name instead:
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/devportfolio
JWT_SECRET=replace_with_minimum_32_character_secret
JWT_EXPIRES_IN=1d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app,https://your-custom-domain.com
# Optional: allow preview deployment domains using a regex pattern.
# Do not use permissive patterns like .* or ^.*$.
# ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$
# Temporary recovery mode for deployment when Atlas is unreachable.
# ALLOW_START_WITHOUT_DB=true
TRUST_PROXY_HOPS=1
DB_MAX_POOL_SIZE=25
DB_MIN_POOL_SIZE=5

# Cashfree payment integration
CASHFREE_APP_ID=replace_with_cashfree_app_id
CASHFREE_SECRET_KEY=replace_with_cashfree_secret_key
# Use sandbox for testing and production for live transactions.
CASHFREE_ENVIRONMENT=sandbox
# Optional but strongly recommended for webhook signature verification.
CASHFREE_WEBHOOK_SECRET=replace_with_cashfree_webhook_secret

# Receipt and support configuration
PAYMENT_BUSINESS_NAME=Nikhil Agrahari
PAYMENT_SUPPORT_EMAIL=nikhilagrahari530@gmail.com
PAYMENT_REFUND_POLICY_URL=https://your-frontend-domain.vercel.app/refund-policy
# Required in production. Keep it long and random.
PAYMENT_RECEIPT_TOKEN_SECRET=replace_with_long_random_secret
PAYMENT_ACCESS_CODE_TTL_MINUTES=10
PAYMENT_PORTAL_TOKEN_TTL_MINUTES=30
PAYMENT_DOWNLOAD_TOKEN_TTL_MINUTES=20

# Receipt email delivery (Resend)
# Keep false until RESEND_API_KEY and PAYMENT_FROM_EMAIL are configured.
PAYMENT_RECEIPT_EMAIL_ENABLED=false
RESEND_API_KEY=re_xxxxxxxxx
PAYMENT_FROM_EMAIL="Payments <payments@yourdomain.com>"
