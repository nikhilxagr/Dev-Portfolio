NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/devportfolio
# Optional alias if your platform provides this name instead:
# DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/devportfolio
JWT_SECRET=replace_with_minimum_32_character_secret
JWT_EXPIRES_IN=1d
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app,https://your-custom-domain.com
# Optional: allow preview deployment domains using a regex pattern.
# ALLOWED_ORIGIN_REGEX=^https://.*\.vercel\.app$
# Temporary recovery mode for deployment when Atlas is unreachable.
# ALLOW_START_WITHOUT_DB=true
DB_MAX_POOL_SIZE=25
DB_MIN_POOL_SIZE=5
